# Production web env for docker-compose.prod.yml.
# Run scripts/ec2/rebrand-env.sh to set domain.
# Copy to ~/.env.web.production on EC2.
# NEXT_PUBLIC_* are baked at build time – change and rebuild if needed.

NODE_ENV=production
PORT=3000
NEXT_PUBLIC_FRONTEND_URL=https://your-app.binaryexperiments.com

API_URL=http://api:4000
TRPC_URL=http://api:4000/trpc
NEXT_PUBLIC_TRPC_URL=/trpc

LOG_LEVELS=All
